# yaml-language-server: $schema=https://www.schemastore.org/clang-tidy.json

Checks: >
  -*,
  bugprone-*,
    -bugprone-easily-swappable-parameters,
    -bugprone-narrowing-conversions,
  clang-diagnostic-*,
  clang-analyzer-*,
  misc-*,
    -misc-no-recursion,
    -misc-non-private-member-variables-in-classes,
    -misc-use-anonymous-namespace,
  modernize-*,
    -modernize-use-auto,
    -modernize-use-trailing-return-type,
  performance-*,
    -performance-avoid-endl,
    -performance-enum-size,
  readability-*,
    -readability-uppercase-literal-suffix,
    -readability-function-cognitive-complexity,
    -readability-identifier-length,
    -readability-magic-numbers,
    -readability-simplify-boolean-expr

# Treat bug detection as build-breaking issues.
WarningsAsErrors: >
  bugprone-*,
  clang-analyzer-*

# Restrict analysis to the project's source files.
HeaderFilterRegex: "^(src|include)/.*"

# Use the project's clang-format configuration for suggested fixes.
FormatStyle: file

# Ignore diagnostics originating from system headers.
SystemHeaders: false

CheckOptions:
  #
  # Naming conventions
  #

  # Namespaces
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case

  # Types
  - key: readability-identifier-naming.ClassCase
    value: CamelCase

  - key: readability-identifier-naming.StructCase
    value: CamelCase

  - key: readability-identifier-naming.EnumCase
    value: CamelCase

  - key: readability-identifier-naming.EnumConstantCase
    value: CamelCase

  - key: readability-identifier-naming.TypeAliasCase
    value: CamelCase

  - key: readability-identifier-naming.TemplateParameterCase
    value: CamelCase

  # Functions
  - key: readability-identifier-naming.FunctionCase
    value: camelBack

  # Variables
  - key: readability-identifier-naming.VariableCase
    value: camelBack

  # Member variables
  - key: readability-identifier-naming.PrivateMemberPrefix
    value: "m_"

  - key: readability-identifier-naming.ProtectedMemberPrefix
    value: "m_"

  # Static data members
  - key: readability-identifier-naming.ClassMemberPrefix
    value: "s_"

  # Globals (discouraged)
  - key: readability-identifier-naming.GlobalVariablePrefix
    value: "g_"

  # Constants
  - key: readability-identifier-naming.ConstexprVariableCase
    value: CamelCase

  - key: readability-identifier-naming.GlobalConstantCase
    value: CamelCase

  - key: readability-identifier-naming.StaticConstantCase
    value: CamelCase

  # Macros
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE

  #
  # Readability
  #

  - key: readability-magic-numbers.IgnoredIntegerValues
    value: "0;1;2;-1"

  - key: readability-magic-numbers.IgnoredFloatingPointValues
    value: "0.0;0.5;1.0;-1.0"

  #
  # Modernize
  #

  - key: modernize-use-auto.MinTypeNameLength
    value: "3"

  - key: modernize-use-auto.RemoveStars
    value: "false"

  #
  # Performance
  #

  - key: performance-unnecessary-value-param.AllowedTypes
    value: ""